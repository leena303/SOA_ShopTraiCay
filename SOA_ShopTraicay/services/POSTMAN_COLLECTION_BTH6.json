{
  "info": {
    "name": "BTH6 - Quy trình mua hàng",
    "description": "Collection test quy trình mua hàng hoàn chỉnh - Bài thực hành số 6",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Xem sản phẩm",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3001/products",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3001",
          "path": ["products"]
        },
        "description": "Khách hàng xem danh sách sản phẩm có sẵn"
      }
    },
    {
      "name": "2. Đăng nhập",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    const jsonData = pm.response.json();",
              "    if (jsonData.token) {",
              "        pm.environment.set(\"jwt_token\", jsonData.token);",
              "        console.log(\"Token saved:\", jsonData.token);",
              "    }",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userName\": \"admin\",\n  \"password\": \"123456\"\n}"
        },
        "url": {
          "raw": "http://localhost:3000/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["login"]
        },
        "description": "Đăng nhập để lấy JWT token"
      }
    },
    {
      "name": "3. Tạo đơn hàng",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "    const jsonData = pm.response.json();",
              "    if (jsonData.data && jsonData.data.id) {",
              "        pm.environment.set(\"order_id\", jsonData.data.id);",
              "        console.log(\"Order ID saved:\", jsonData.data.id);",
              "    }",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customer_name\": \"Nguyễn Văn A\",\n  \"customer_email\": \"nguyenvana@example.com\",\n  \"items\": [\n    {\n      \"product_id\": 1,\n      \"quantity\": 2\n    },\n    {\n      \"product_id\": 2,\n      \"quantity\": 3\n    }\n  ],\n  \"payment_method\": \"cash\",\n  \"notes\": \"Giao hàng buổi sáng\"\n}"
        },
        "url": {
          "raw": "http://localhost:3002/orders",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3002",
          "path": ["orders"]
        },
        "description": "Tạo đơn hàng mới với danh sách sản phẩm"
      }
    },
    {
      "name": "4. Thêm sản phẩm vào đơn hàng (Tùy chọn)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"order_id\": {{order_id}},\n  \"product_id\": 3,\n  \"quantity\": 1,\n  \"unit_price\": 60000\n}"
        },
        "url": {
          "raw": "http://localhost:3002/order_items",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3002",
          "path": ["order_items"]
        },
        "description": "Thêm sản phẩm vào đơn hàng đã tạo"
      }
    },
    {
      "name": "5. Cập nhật số lượng sản phẩm (Tùy chọn)",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"quantity\": 95\n}"
        },
        "url": {
          "raw": "http://localhost:3001/products/1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3001",
          "path": ["products", "1"]
        },
        "description": "Cập nhật số lượng sản phẩm trong kho"
      }
    },
    {
      "name": "6. Cập nhật trạng thái đơn hàng",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"completed\"\n}"
        },
        "url": {
          "raw": "http://localhost:3002/orders/{{order_id}}/status",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3002",
          "path": ["orders", "{{order_id}}", "status"]
        },
        "description": "Cập nhật trạng thái đơn hàng sau khi thanh toán và vận chuyển"
      }
    },
    {
      "name": "7. Tạo báo cáo đơn hàng",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "    const jsonData = pm.response.json();",
              "    if (jsonData.data && jsonData.data.id) {",
              "        pm.environment.set(\"order_report_id\", jsonData.data.id);",
              "        console.log(\"Order Report ID saved:\", jsonData.data.id);",
              "    }",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"order_id\": {{order_id}}\n}"
        },
        "url": {
          "raw": "http://localhost:3003/reports/orders",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3003",
          "path": ["reports", "orders"]
        },
        "description": "Tạo báo cáo đơn hàng (tự động tính revenue, cost, profit)"
      }
    },
    {
      "name": "8. Xem thống kê đơn hàng",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3003/reports/orders",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3003",
          "path": ["reports", "orders"]
        },
        "description": "Lấy danh sách tất cả báo cáo đơn hàng"
      }
    },
    {
      "name": "9. Xem chi tiết báo cáo đơn hàng",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3003/reports/orders/{{order_report_id}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3003",
          "path": ["reports", "orders", "{{order_report_id}}"]
        },
        "description": "Lấy chi tiết báo cáo đơn hàng (bao gồm product_reports)"
      }
    },
    {
      "name": "10. Xem thống kê sản phẩm",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3003/reports/products",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3003",
          "path": ["reports", "products"]
        },
        "description": "Lấy danh sách tất cả báo cáo sản phẩm"
      }
    },
    {
      "name": "11. Xem tổng hợp sản phẩm",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3003/reports/products/1/summary",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3003",
          "path": ["reports", "products", "1", "summary"]
        },
        "description": "Lấy báo cáo tổng hợp theo product_id"
      }
    }
  ],
  "variable": [
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "order_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "order_report_id",
      "value": "",
      "type": "string"
    }
  ]
}

